# =====================================================
# TASK: FEATURE ENGINEERING ON HOUSING DATASET
# =====================================================

# Import Libraries
import pandas as pd
from sklearn.datasets import fetch_california_housing
from sklearn.preprocessing import StandardScaler

# =====================================================
# LOAD DATASET
# =====================================================

housing = fetch_california_housing()

df = pd.DataFrame(
    housing.data,
    columns=housing.feature_names
)

df['HouseValue'] = housing.target

print("First 5 Rows:")
print(df.head())

print("\nDataset Shape:", df.shape)

# =====================================================
# FEATURE ENGINEERING
# =====================================================

# 1. Create a categorical feature
df['Income_Category'] = pd.cut(
    df['MedInc'],
    bins=[0, 2, 4, 6, 15],
    labels=['Low', 'Medium', 'High', 'Very High']
)

# =====================================================
# ONE-HOT ENCODING
# =====================================================

df_encoded = pd.get_dummies(
    df,
    columns=['Income_Category']
)

# =====================================================
# FEATURE SCALING
# =====================================================

numerical_cols = [
    'MedInc',
    'HouseAge',
    'AveRooms',
    'AveBedrms',
    'Population',
    'AveOccup',
    'Latitude',
    'Longitude'
]

scaler = StandardScaler()

df_encoded[numerical_cols] = scaler.fit_transform(
    df_encoded[numerical_cols]
)

# =====================================================
# INTERACTION FEATURES
# =====================================================

df_encoded['Rooms_Per_Person'] = (
    df['AveRooms'] / df['Population']
)

df_encoded['Income_HouseAge'] = (
    df['MedInc'] * df['HouseAge']
)

# =====================================================
# DISPLAY RESULT
# =====================================================

print("\nEngineered Dataset:")
print(df_encoded.head())

print("\nFinal Shape:", df_encoded.shape)

# =====================================================
# REPORT
# =====================================================

print("\n" + "="*50)
print("FEATURE ENGINEERING REPORT")
print("="*50)

print("""
1. California Housing Dataset was loaded.

2. Income_Category feature was created.

3. One-Hot Encoding was applied to categorical data.

4. Numerical features were standardized using StandardScaler.

5. Interaction features were created:
   - Rooms_Per_Person
   - Income_HouseAge

6. Dataset became more suitable for machine learning.

Conclusion:
Feature engineering improved data quality and
prepared the dataset for predictive modeling.
""")
